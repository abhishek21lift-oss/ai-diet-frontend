# ─────────────────────────────────────────
# 619 FITNESS STUDIO — ENVIRONMENT CONFIG
# ─────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/fitness_619?schema=public"

# JWT Secrets
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude AI
ANTHROPIC_API_KEY=sk-ant-api03-...

# AWS S3 (for progress photos)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
AWS_S3_BUCKET=619-fitness-uploads

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_ROUNDS=12
