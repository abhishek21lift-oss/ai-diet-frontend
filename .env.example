# ─────────────────────────────────────────
# 619 FITNESS STUDIO — ENVIRONMENT CONFIG
# Free Tier: MongoDB Atlas (M0) + Render
# ─────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# MongoDB Atlas — get free URI from https://cloud.mongodb.com (M0 free tier)
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/fitness_619?retryWrites=true&w=majority

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Anthropic Claude AI (free signup: https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Bcrypt
BCRYPT_ROUNDS=12
